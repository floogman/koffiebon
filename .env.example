APP_NAME=Koffiebon
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8090
APP_TIMEZONE=Europe/Amsterdam
APP_SERVICE=laravel.bon

# Container user/group (gebruikt door docker-compose build/runtime).
# Normaal zet de `sail`-wrapper deze automatisch; expliciet voor `docker compose`.
WWWGROUP=1000
WWWUSER=1000

# Poorten 80/5173 zijn op deze machine bezet door een ander Sail-project,
# daarom wijkt de app-poort af. Pas aan als die poorten vrij zijn.
APP_PORT=8090
VITE_PORT=5273
# Mailpit host-poorten (standaard 1025/8025 zijn bezet op deze machine)
FORWARD_MAILPIT_PORT=1027
FORWARD_MAILPIT_DASHBOARD_PORT=8027

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Lokaal dev draait op SQLite (database/database.sqlite, de Laravel-default).
# Laat DB_DATABASE leeg voor SQLite — anders wordt dat als bestandspad gebruikt.
# Pgsql-waarden hieronder gelden alleen als je DB_CONNECTION op pgsql zet en
# `sail --profile pgsql up` draait:
# DB_HOST=pgsql
# DB_PORT=5432
# DB_DATABASE=koffiebon
# DB_USERNAME=sail
# DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@koffiebon.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

MOLLIE_API_KEY=
