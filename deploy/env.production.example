# Koffiebon — productie .env voorbeeld (kopieer naar /var/www/koffie.klusviewer.nl/.env)
# Vite leest de VITE_*-variabelen uit DIT bestand tijdens `npm run build`.

APP_NAME=Koffiebon
APP_ENV=production
APP_KEY=                              # vul met: php artisan key:generate
APP_DEBUG=false
APP_URL=https://koffie.klusviewer.nl
APP_TIMEZONE=Europe/Amsterdam
APP_LOCALE=nl
APP_FALLBACK_LOCALE=nl

# Host waar de PWA + QR-deeplinks (/s/{nonce}) + claim-link op staan = dit subdomein.
FRONTEND_URL=https://koffie.klusviewer.nl

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ---- Database: SQLite ----
DB_CONNECTION=sqlite
# Standaard: database/database.sqlite (maak het bestand aan, zie DEPLOY.md)

# ---- Drivers ----
SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# ---- Mail: ECHTE SMTP invullen (Mailpit bestaat niet op productie!) ----
# Zonder werkende SMTP komen registratie-/magic-link-mails niet aan.
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="no-reply@klusviewer.nl"
MAIL_FROM_NAME="Koffiebon"

# ---- Reverb (genereer VERSE secrets; gebruik NIET de voorbeeldwaarden uit .env.example) ----
# Publieke host = subdomein op 443/https; Reverb zelf bindt lokaal op 8081
# (8080 is op deze VPS al in gebruik).
REVERB_APP_ID=koffiebon
REVERB_APP_KEY=                       # vul vers in (bv. `openssl rand -hex 16`)
REVERB_APP_SECRET=                    # vul vers in (bv. `openssl rand -hex 32`)
REVERB_HOST=koffie.klusviewer.nl
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8081

# ---- Frontend build (Vite) — leest dezelfde waarden ----
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ---- Mollie (fase 2; leeg laten in fase 1) ----
MOLLIE_API_KEY=
